start /b powershell -Command "Add-Type -AssemblyName Microsoft.VisualBasic; Add-Type -AssemblyName System.Windows.Forms; cd C:\Users\%USERNAME%\kohya_ss; $p = Start-Process cmd -ArgumentList '/k title KohyaRunner && .\setup.bat' -PassThru; Start-Sleep -Seconds 3; [Microsoft.VisualBasic.Interaction]::AppActivate('KohyaRunner'); Start-Sleep -Milliseconds 300; [System.Windows.Forms.SendKeys]::SendWait('6{ENTER}'); Start-Sleep -Seconds 2; Get-WmiObject Win32_Process | Where-Object { $_.ParentProcessId -eq $p.Id } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }; Stop-Process -Id $p.Id -Force" && exit